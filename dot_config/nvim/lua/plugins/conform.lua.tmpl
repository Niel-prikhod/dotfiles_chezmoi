return {
	{
		"stevearc/conform.nvim",
		tag = "v9.1.0",
		config = function()
			require("conform").setup({
{{- if hasSuffix "@rockwellautomation.com" .email }}
				-- Work machine: format C/C++ with the company clang-format config.
				-- Triggered manually via :Format (no autoformat, no hotkey).
				formatters = {
					clang_format = {
						prepend_args = {
							"--style=file:{{ .chezmoi.homeDir }}/Projects/SI/Scripts/catscripts/clang_format/.clang-format",
						},
					},
				},
				formatters_by_ft = {
					c = { "clang_format" },
					cpp = { "clang_format" },
				},
{{- else }}
				format_on_save = function(bufnr)
					local filetype = vim.bo[bufnr].filetype
					if filetype ~= "c" and filetype ~= "cpp" then
						return { timeout_ms = 500, lsp_format = "fallback" }
					end
				end,
				formatters_by_ft = {},
{{- end }}
			})

			-- :Format [range] — manual formatting entry point (bind as you like).
			vim.api.nvim_create_user_command("Format", function(args)
				local range = nil
				if args.count ~= -1 then
					local end_line = vim.api.nvim_buf_get_lines(0, args.line2 - 1, args.line2, true)[1]
					range = {
						start = { args.line1, 0 },
						["end"] = { args.line2, end_line:len() },
					}
				end
				require("conform").format({ async = true, lsp_format = "fallback", range = range })
			end, { range = true, desc = "Format buffer/range with conform" })
		end,
	},
}
